// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// 1. TABELA DE LIVROS (O Acervo da Biblioteca)
model Livro {
  id        Int       @id @default(autoincrement()) 
  isbn      String    
  titulo    String    
  autor     String?   
  capaUrl   String?   
  sinopse   String?   
  status    String    @default("Disponivel")  
  reservas  Reserva[]
}

model Reserva {
  id              Int      @id @default(autoincrement())
  livroId         Int      
  nomeLeitor      String   
  cpfLeitor       String  
  telefoneContato String?
  dataReserva     DateTime @default(now()) 
  statusReserva   String   @default("Pendente") 
  livro           Livro    @relation(fields: [livroId], references: [id], onDelete: Cascade)
}